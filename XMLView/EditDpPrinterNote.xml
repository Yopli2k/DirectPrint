<view>
    <columns>
        <column name="id" numcolumns="1" display="none" order="100">
            <widget type="number" fieldname="id" readonly="true" required="true"/>
        </column>
        <column name="notes" numcolumns="12" order="110">
            <widget type="textarea" fieldname="notes" rows="5"/>
        </column>
    </columns>
</view>
