    Description:
        List view for the print routes. Rows are created by code (registerRoute);
        the admin only assigns a printer to each action.
-->

<view>
    <columns>
        <column name="action" order="100">
            <widget type="text" fieldname="slug"/>
        </column>
        <column name="name" order="110">
            <widget type="text" fieldname="name"/>
        </column>
        <column name="printer" order="120">
            <widget type="select" fieldname="idprinter">
                <values source="directprint_printers" fieldcode="id" fieldtitle="name"/>
            </widget>
        </column>
    </columns>
</view>
