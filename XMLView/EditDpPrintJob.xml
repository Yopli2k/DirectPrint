<view>
    <columns>
        <column name="date" numcolumns="3" order="100">
            <widget type="datetime" fieldname="creation_date" readonly="true"/>
        </column>
        <column name="printer" numcolumns="3" order="110">
            <widget type="select" fieldname="idprinter" readonly="true">
                <values source="directprint_printers" fieldcode="id" fieldtitle="name"/>
            </widget>
        </column>
        <column name="user" numcolumns="3" order="120">
            <widget type="text" fieldname="nick" readonly="true"/>
        </column>
        <column name="status" numcolumns="3" order="130">
            <widget type="text" fieldname="status" readonly="true"/>
        </column>
        <column name="file" numcolumns="4" order="140">
            <widget type="text" fieldname="filename" readonly="true"/>
        </column>
        <column name="type" numcolumns="4" order="150">
            <widget type="text" fieldname="mimetype" readonly="true"/>
        </column>
        <column name="cups-job-id" numcolumns="4" order="160">
            <widget type="text" fieldname="cups_job_id" readonly="true"/>
        </column>
        <column name="options" numcolumns="12" order="170">
            <widget type="textarea" fieldname="options" readonly="true"/>
        </column>
        <column name="common-error" numcolumns="12" order="180">
            <widget type="textarea" fieldname="error" readonly="true"/>
        </column>
        <column name="source-plugin" numcolumns="4" order="190">
            <widget type="text" fieldname="source_plugin" readonly="true"/>
        </column>
        <column name="source-model" numcolumns="4" order="200">
            <widget type="text" fieldname="source_model" readonly="true"/>
        </column>
        <column name="source-id" numcolumns="4" order="210">
            <widget type="text" fieldname="source_id" readonly="true"/>
        </column>
    </columns>
</view>
