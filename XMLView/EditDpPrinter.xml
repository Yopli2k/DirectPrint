<view>
    <columns>
        <column name="name" numcolumns="6" order="100">
            <widget type="text" fieldname="name" required="true"/>
        </column>
        <column name="queue" numcolumns="6" order="110">
            <widget type="text" fieldname="queue" required="true"/>
        </column>
        <column name="paper" numcolumns="3" order="120">
            <widget type="select" fieldname="paper">
                <values title="A4">A4</values>
                <values title="A5">A5</values>
                <values title="Letter">Letter</values>
                <values title="Legal">Legal</values>
            </widget>
        </column>
        <column name="orientation" numcolumns="3" order="130">
            <widget type="select" fieldname="orientation">
                <values title="portrait">portrait</values>
                <values title="landscape">landscape</values>
            </widget>
        </column>
        <column name="copies" numcolumns="2" order="140">
            <widget type="number" fieldname="copies" min="1" step="1"/>
        </column>
        <column name="active" numcolumns="2" order="150">
            <widget type="checkbox" fieldname="active"/>
        </column>
        <column name="default" numcolumns="2" order="160">
            <widget type="checkbox" fieldname="bydefault"/>
        </column>
        <column name="notes" numcolumns="12" order="170">
            <widget type="textarea" fieldname="notes"/>
        </column>
    </columns>
</view>
