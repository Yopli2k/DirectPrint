    Description:
        Structure of the print routes table.
        One record per action registered by a plugin, mapping its slug to a printer.
        A null printer means the default printer is used.
-->

<table>
    <column>
        <name>id</name>
        <type>serial</type>
        <null>NO</null>
    </column>
    <column>
        <name>idprinter</name>
        <type>integer</type>
    </column>
    <column>
        <name>name</name>
        <type>character varying(120)</type>
    </column>
    <column>
        <name>slug</name>
        <type>character varying(60)</type>
        <null>NO</null>
    </column>
    <constraint>
        <name>directprint_routes_pkey</name>
        <type>PRIMARY KEY (id)</type>
    </constraint>
    <constraint>
        <name>uniq_directprint_routes_slug</name>
        <type>UNIQUE (slug)</type>
    </constraint>
    <constraint>
        <name>ca_directprint_routes_printer</name>
        <type>FOREIGN KEY (idprinter) REFERENCES directprint_printers (id) ON DELETE SET NULL ON UPDATE CASCADE</type>
    </constraint>
</table>
